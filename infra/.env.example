# Legend Dad — Infrastructure Environment Variables
# Copy this file to infra/.env and fill in your keys

# === Model Providers (round-robin rotation) ===

# Z.AI (GLM models)
ZAI_BASE_URL=https://api.z.ai/api/coding/paas/v4
ZAI_API_KEY=
ZAI_MODEL=glm-5.1

# Alibaba Cloud (Qwen models)
ALIBABA_BASE_URL=https://coding-intl.dashscope.aliyuncs.com/v1
ALIBABA_API_KEY=
ALIBABA_MODEL=qwen3.5-plus

# === SurrealDB ===
SURREAL_URL=ws://localhost:6480
SURREAL_NS=legend_dad
SURREAL_DB=replay
SURREAL_USER=root
SURREAL_PASS=root

# === Game Server ===
PORT=3000
SERVE_PORT=8080

# OS
.DS_Store
Thumbs.db

# Godot
project/hosts/complete-app/.godot/

# Build artifacts
build/_artifacts/*
!build/_artifacts/.gitkeep
build/_certs/
build/tilesets/
project/build/

# Generated build metadata (regenerated each `task build` from gitversion)
project/shared/data/build_version.txt

# Node
node_modules/
*.tgz

# Python
__pycache__/
*.pyc
.venv/

# Obsidian volatile
vault/.obsidian/workspace.json
vault/.obsidian/workspace-mobile.json
vault/.obsidian/plugins/*/data.json

# IDE
.vscode/
.idea/
*.swp
*.swo

# Environment files (contain secrets)
infra/.env
infra/.env.local
.env
.env.local
.env.*.local

# Articy MDK plugin build artifacts
project/articy/mdk-plugin/**/bin/
project/articy/mdk-plugin/**/obj/
project/articy/mdk-plugin/**/*.csx
project/articy/mdk-plugin/**/dump-types.csproj
project/articy/mdk-plugin/**/ApiInspector.cs

# Articy project volatile files
project/articy/legend-dad/Assets.sqlite
project/articy/legend-dad/Sessions/
project/articy/legend-dad/ProjectInfo.lck

# Superpowers brainstorm sessions
.superpowers/

# godot-api skill — generated per-class API docs + upstream sparse clone
.agent/skills/01-godot/godot-api/doc_api/
.agent/skills/01-godot/godot-api/doc_source/

# External reference checkouts — not part of this repo
ref-projects/

# Git worktrees for parallel feature work
.worktrees/

# Cross-platform links to project/shared/ — recreated by `task share:link`.
# Do NOT commit files inside these — edit under project/shared/ instead.
# Patterns lack trailing slashes so they match symlinks (Mac/Linux),
# which gitignore treats as files, not directories.
project/hosts/complete-app/addons
project/hosts/complete-app/lib
project/hosts/complete-app/shaders
project/hosts/complete-app/data
project/hosts/content-app/addons
project/hosts/content-app/lib
project/hosts/content-app/shaders
project/hosts/content-app/data
project/hosts/content-app/content

# Godot cache for the new project too
project/hosts/content-app/.godot/

# Dev symlink: serves PCKs from build/_artifacts/pck/ during local headless runs.
# Recreate with: ln -s ../../../build/_artifacts/pck project/hosts/complete-app/pck
project/hosts/complete-app/pck

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Content Manifest",
  "type": "object",
  "required": ["schema_version", "bundles"],
  "properties": {
    "schema_version": { "const": 1 },
    "bundles": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["kind", "policy", "pck", "deps"],
        "properties": {
          "kind": { "enum": ["hud", "enemies", "npcs", "items", "dialogue", "location"] },
          "policy": { "enum": ["eager", "lazy"] },
          "pck": { "type": "string", "pattern": "^[a-z0-9-]+@[0-9a-f]+\\.pck$" },
          "deps": { "type": "array", "items": { "type": "string" } },
          "provides": {
            "type": "object",
            "additionalProperties": {
              "type": "array",
              "items": { "type": "string" }
            }
          },
          "content_hash": { "type": "string", "pattern": "^[0-9a-f]+$" }
        },
        "additionalProperties": false
      }
    }
  }
}
